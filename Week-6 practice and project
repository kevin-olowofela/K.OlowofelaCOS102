import tkinter as tk
from tkinter import messagebox
import random

class Employee:
    def __init__(self):
        self.employees = [
            "Mary Evans", "Eyo Ishan", "Durojaiye Dare", "Adams Ali", 
            "Andrew Ugwu", "Stella Mankinde", "Jane Akibo", "Ago James", 
            "Michell Taiwo", "Abraham Jones", "Nicole Anide", "Kosi Korso", 
            "Adele Martins", "Emmanuel Ojo", "Ajayi Fatima"
        ]
        self.tasks = ["Loading", "Transporting", "Reviewing Orders", "Customer Service", "Delivering Items"]
        
        self.window = tk.Tk()
        self.window.title("Logistics Employee Portal")
        self.window.geometry("450{c}300".format(c="x"))
        self.window.config(bg="#f4f4f4")
        
        self.label_title = tk.Label(self.window, text="Employee Identity & Assignment System", font=("Helvetica", 14, "bold"), bg="#f4f4f4", fg="#333")
        self.label_title.pack(pady=15)
        
        self.label_prompt = tk.Label(self.window, text="Enter Your Full Name:", font=("Helvetica", 11), bg="#f4f4f4")
        self.label_prompt.pack(pady=5)
        
        self.entry_name = tk.Entry(self.window, font=("Helvetica", 12), width=30, bd=2)
        self.entry_name.pack(pady=5)
        
        self.btn_submit = tk.Button(self.window, text="Verify identity", font=("Helvetica", 11, "bold"), bg="#2b6cb0", fg="white", width=18, command=self.check_employee)
        self.btn_submit.pack(pady=20)

    def check_employee(self):
        input_name = self.entry_name.get().strip()
        
        if not input_name:
            messagebox.showwarning("Input Error", "Please enter a name to proceed.")
            return
            
        matched_employee = next((emp for emp in self.employees if emp.lower() == input_name.lower()), None)
        
        if matched_employee:
            self.take_attendance(matched_employee)
        else:
            self.refuse_access(input_name)

    def take_attendance(self, employee_name):
        attendance_log_msg = f"Attendance logged successfully for {employee_name}.\n"
        self.assign_task(employee_name, attendance_log_msg)

    def assign_task(self, employee_name, internal_status_msg):
        assigned_job = random.choice(self.tasks)
        final_success_msg = internal_status_msg + f"Your assigned operational task for today is: {assigned_job}."
        messagebox.showinfo("Access Granted", final_success_msg)
        self.entry_name.delete(0, tk.END)

    def refuse_access(self, unrecognized_name):
        rejection_text = f"Access Denied. Verification failed for '{unrecognized_name}'. You are not registered in the system."
        messagebox.showerror("Access Denied", rejection_text)

    def run(self):
        self.window.mainloop()


class DeliveryCalculator:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Logistics Pricing Calculator")
        self.root.geometry("450{c}350".format(c="x"))
        self.root.config(bg="#e2e8f0")
        
        self.title_lbl = tk.Label(self.root, text="Delivery Fee Assessment System", font=("Helvetica", 14, "bold"), bg="#e2e8f0", fg="#2d3748")
        self.title_lbl.pack(pady=15)
        
        self.loc_lbl = tk.Label(self.root, text="Select Destination Location:", font=("Helvetica", 11), bg="#e2e8f0")
        self.loc_lbl.pack(pady=5)
        
        self.selected_location = tk.StringVar(self.root)
        self.selected_location.set("PAU")
        self.dropdown_menu = tk.OptionMenu(self.root, self.selected_location, "PAU", "Epe")
        self.dropdown_menu.config(font=("Helvetica", 11), width=15)
        self.dropdown_menu.pack(pady=5)
        
        self.weight_lbl = tk.Label(self.root, text="Enter Package Weight (kg):", font=("Helvetica", 11), bg="#e2e8f0")
        self.weight_lbl.pack(pady=5)
        
        self.weight_entry = tk.Entry(self.root, font=("Helvetica", 12), width=15, bd=2)
        self.weight_entry.pack(pady=5)
        
        self.calc_btn = tk.Button(self.root, text="Calculate Cost", font=("Helvetica", 11, "bold"), bg="#38a169", fg="white", width=18, command=self.process_fee_calculation)
        self.calc_btn.pack(pady=20)

    def process_fee_calculation(self):
        destination = self.selected_location.get()
        raw_weight_input = self.weight_entry.get().strip()
        
        try:
            package_weight = float(raw_weight_input)
            if package_weight <= 0:
                raise ValueError("Weight value must be greater than zero.")
        except ValueError:
            messagebox.showerror("Validation Error", "Please provide a valid structural numeric weight input.")
            return

        calculated_charge = 0
        if destination == "PAU":
            if package_weight >= 10.0:
                calculated_charge = 2000
            else:
                calculated_charge = 1500
        elif destination == "Epe":
            if package_weight >= 10.0:
                calculated_charge = 5000
            else:
                calculated_charge = 4000
                
        result_message = f"Destination Location: {destination}\nPackage Total Weight: {package_weight} kg\n\nTotal Due: N{calculated_charge:,}"
        messagebox.showinfo("Calculation Receipt Invoice", result_message)
        self.weight_entry.delete(0, tk.END)

    def run(self):
        self.root.mainloop()


