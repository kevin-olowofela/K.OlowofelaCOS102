            "Transborder advisory services",
            "Liquidity management"
        ]


class CommercialBanking(zenith):
    def unique_services(self):
        return [
            "Advisory services"
        ]


class ZenithPortal:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("Zenith Bank Division Services Portal")
        self.root.geometry("500{c}450".format(c="x"))
        self.root.config(bg="#f4f4f6")

        self.title_label = tk.Label(
            self.root, 
            text="Zenith Bank Employee Portal", 
            font=("Helvetica", 14, "bold"), 
            bg="#f4f4f6", 
            fg="#1a365d"
        )
        self.title_label.pack(pady=15)

        self.name_label = tk.Label(self.root, text="Employee Name:", font=("Helvetica", 11), bg="#f4f4f6")
        self.name_label.pack(pady=2)
        
        self.name_entry = tk.Entry(self.root, font=("Helvetica", 11), width=30)
        self.name_entry.pack(pady=5)

        self.div_label = tk.Label(self.root, text="Select Division:", font=("Helvetica", 11), bg="#f4f4f6")
        self.div_label.pack(pady=2)

        self.divisions = ["Retail Banking", "Global Banking", "Commercial Banking"]
        self.div_combobox = ttk.Combobox(self.root, values=self.divisions, font=("Helvetica", 10), state="readonly", width=28)
        self.div_combobox.set("Retail Banking")
        self.div_combobox.pack(pady=5)

        self.submit_btn = tk.Button(
            self.root, 
            text="Fetch Services", 
            font=("Helvetica", 11, "bold"), 
            bg="#1a365d", 
            fg="white", 
            width=20, 
            command=self.display_division_services
        )
        self.submit_btn.pack(pady=15)

        self.result_frame = tk.LabelFrame(self.root, text="Rendered Services Result", font=("Helvetica", 10, "bold"), bg="#f4f4f6", padx=10, pady=10)
        self.result_frame.pack(pady=10, fill="both", expand=True, padx=20)

        self.result_text = tk.Text(self.result_frame, font=("Helvetica", 10), bg="white", wrap="word", height=10)
        self.result_text.pack(fill="both", expand=True)

    def display_division_services(self):
        emp_name = self.name_entry.get().strip()
        selected_div = self.div_combobox.get()

        if not emp_name:
            messagebox.showwarning("Validation Error", "Please enter an employee name.")
            return

        if selected_div == "Retail Banking":
            division_obj = RetailBanking()
        elif selected_div == "Global Banking":
            division_obj = GlobalBanking()
        elif selected_div == "Commercial Banking":
            division_obj = CommercialBanking()
        else:
            messagebox.showerror("Error", "Invalid division selected.")
            return

        mutual = division_obj.mutual_services()
        unique = division_obj.unique_services()

        self.result_text.delete("1.0", tk.END)
        
        greeting = "Employee: " + emp_name + "\n"
        division_info = "Division: " + selected_div + "\n"
        separator = "=" * 40 + "\n\n"
        
        self.result_text.insert(tk.END, greeting)
        self.result_text.insert(tk.END, division_info)
        self.result_text.insert(tk.END, separator)

        if mutual:
            self.result_text.insert(tk.END, "Mutual Services:\n")
            for service in mutual:
                self.result_text.insert(tk.END, " - " + service + "\n")
            self.result_text.insert(tk.END, "\n")

        if unique:
            self.result_text.insert(tk.END, "Unique/Exclusive Services:\n")
            for service in unique:
                self.result_text.insert(tk.END, " - " + service + "\n")

    def run(self):
        self.root.mainloop()


if __name__ == "__main__":
    portal = ZenithPortal()
    portal.run()
