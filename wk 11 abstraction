class VendorPortal:
    def __init__(self):
        self.root = tk.Tk()
        self.root.title("PAU External Food Vendors Management System")
        self.root.geometry("500x450")
        self.root.config(bg="#f8fafc")

        self.title_label = tk.Label(
            self.root, 
            text="PAU External Food Vendors Portal", 
            font=("Helvetica", 14, "bold"), 
            bg="#f8fafc", 
            fg="#0f172a"
        )
        self.title_label.pack(pady=15)

        self.vendor_label = tk.Label(self.root, text="Select Vendor of Interest:", font=("Helvetica", 11), bg="#f8fafc")
        self.vendor_label.pack(pady=5)

        self.vendors = ["Cooperative Hostel", "Faith Hostel", "Student Center"]
        self.vendor_combobox = ttk.Combobox(self.root, values=self.vendors, font=("Helvetica", 10), state="readonly", width=25)
        self.vendor_combobox.set("Cooperative Hostel")
        self.vendor_combobox.pack(pady=5)

        self.view_btn = tk.Button(
            self.root, 
            text="Display Menu", 
            font=("Helvetica", 11, "bold"), 
            bg="#0284c7", 
            fg="white", 
            width=18, 
            command=self.show_vendor_menu
        )
        self.view_btn.pack(pady=15)

        self.menu_frame = tk.LabelFrame(self.root, text="Vendor Menu Details", font=("Helvetica", 10, "bold"), bg="#f8fafc", padx=10, pady=10)
        self.menu_frame.pack(pady=10, fill="both", expand=True, padx=25)

        self.menu_text = tk.Text(self.menu_frame, font=("Helvetica", 11), bg="white", wrap="word")
        self.menu_text.pack(fill="both", expand=True)

    def show_vendor_menu(self):
        selected = self.vendor_combobox.get()
        
        if selected == "Cooperative Hostel":
            vendor_obj = CooperativeHostel()
        elif selected == "Faith Hostel":
            vendor_obj = FaithHostel()
        elif selected == "Student Center":
            vendor_obj = StudentCenter()
        else:
            return

        items = vendor_obj.menu()
        self.menu_text.delete("1.0", tk.END)
        self.menu_text.insert(tk.END, "Menu for " + selected + ":\n")
        self.menu_text.insert(tk.END, "=" * 35 + "\n")
        self.menu_text.insert(tk.END, f"{'Main Meal':<25}{'Price (N)':<10}\n")
        self.menu_text.insert(tk.END, "-" * 35 + "\n")
        
        for meal, price in items:
            self.menu_text.insert(tk.END, f"{meal:<25}N{price:<10}\n")

    def run(self):
        self.root.mainloop()

    portal = VendorPortal()
    portal.run()
